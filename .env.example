# Variáveis de ambiente obrigatórias — copie para .env e preencha antes de subir o serviço
# (nunca commite o .env com valores reais)

# Banco de dados PostgreSQL
DB_USERNAME=myuser
DB_PASSWORD=changeme

# Chave RSA para assinatura do JWT
# Dev: deixe em branco — usa a chave bundled em classpath:keys/dev-private-key.pem
# Produção: aponte para o PEM (PKCS#8) da chave privada RSA
JWT_RSA_PRIVATE_KEY_PATH=

# Emissão do token
JWT_ISSUER=http://localhost:8080
JWT_TTL_SEGUNDOS=7200

# SMTP para e-mail de confirmação de cadastro
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-de-app
MAIL_FROM=nao-responda@trilha.com

# URL do link de confirmação de e-mail (dev: localhost, prod: URL pública)
EMAIL_CONFIRMACAO_URL=http://localhost:8080/auth/confirmar-email

# Login social (IDs públicos — não são segredos)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# DDL — dev: update | produção: validate
DDL_AUTO=update
